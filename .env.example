### lightrag-snkv environment configuration
### Copy this file to .env and fill in your values.
###
###   cp .env.example .env

###############################
### Server (web UI via server.py)
###############################
HOST=0.0.0.0
PORT=9621

###############################
### LLM Configuration
### Supported bindings: openai, azure_openai, ollama
###############################
LLM_BINDING=openai
LLM_MODEL=gpt-4o-mini
LLM_BINDING_HOST=https://api.openai.com/v1
LLM_BINDING_API_KEY=your_api_key_here

### Azure OpenAI (set LLM_BINDING=azure_openai and fill these instead)
# LLM_BINDING=azure_openai
# LLM_BINDING_HOST=https://your-resource.openai.azure.com/
# LLM_BINDING_API_KEY=your_azure_api_key
# LLM_MODEL=your-deployment-name
# AZURE_OPENAI_API_VERSION=2024-08-01-preview

### Ollama (set LLM_BINDING=ollama and fill these instead)
# LLM_BINDING=ollama
# LLM_BINDING_HOST=http://localhost:11434
# LLM_MODEL=llama3.2

###############################
### Embedding Configuration
### Supported bindings: openai, azure_openai, ollama
###############################
EMBEDDING_BINDING=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
EMBEDDING_BINDING_HOST=https://api.openai.com/v1
EMBEDDING_BINDING_API_KEY=your_api_key_here

### Azure OpenAI embedding (set EMBEDDING_BINDING=azure_openai and fill these instead)
# EMBEDDING_BINDING=azure_openai
# EMBEDDING_BINDING_HOST=https://your-resource.openai.azure.com/
# EMBEDDING_BINDING_API_KEY=your_azure_api_key
# EMBEDDING_MODEL=text-embedding-3-large
# EMBEDDING_DIM=3072

### Ollama embedding (set EMBEDDING_BINDING=ollama and fill these instead)
# EMBEDDING_BINDING=ollama
# EMBEDDING_BINDING_HOST=http://localhost:11434
# EMBEDDING_MODEL=nomic-embed-text
# EMBEDDING_DIM=768

###############################
### Hacker News Ingestion (ingest_hn.py / server.py background daemon)
###############################

# How far back to fetch posts on the very first run.
# Format: 1y (1 year), 2y (2 years), 4w (4 weeks), 90d (90 days).
# After the first run, only new posts are fetched (incremental).
HN_LOOKBACK=4w

# Daemon schedule: daily | weekly
# Set this to start the HN ingestion daemon automatically when server.py starts,
# or when running: python ingest_hn.py --schedule daily
# Leave commented out to disable the daemon.
# HN_SCHEDULE=daily

# Only ingest posts with at least this many upvotes.
# Higher value = fewer posts, generally higher quality.
# Suggested: 10 (default), 50 (popular), 100 (highly popular)
HN_MIN_SCORE=10

# Number of posts sent to the knowledge graph in one batch.
# Lower value uses less memory; reduce if you hit LLM rate limits.
HN_BATCH_SIZE=10

# Post types to fetch (comma-separated, matched with OR logic).
# ask_hn = Ask HN discussion threads
# show_hn = Show HN project announcements
HN_TAGS=ask_hn,show_hn

# Directory where the HN knowledge graph is stored.
# Kept separate from the main RAG storage.
HN_WORKING_DIR=./hn_rag_storage
